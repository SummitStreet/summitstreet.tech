{
  "name": "summitstreet.tech",
  "version": "1.0.0",
  "private": true,
  "author": "David Padgett <https://github.com/SummitStreet>",
  "license": "MIT",
  "description": "This is https://summitstreet.tech implemented as a Svelte-based app. The static version of this website is located at https://github.com/SummitStreet/summitstreet.github.io.",
  "keywords": [
    "typescript",
    "svelte",
    "web",
    "ui"
  ],
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build:pre": "tsx scripts/pre-build.ts",
    "build:post": "tsx scripts/post-build.ts",
    "build": "npm run build:pre && vite build && npm run build:post",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "npm run build:pre && vite dev",
    "format": "prettier --write . && stylelint --fix '**/*.css' '**/*.svelte'",
    "lint": "eslint . && stylelint '**/*.css' '**/*.svelte'",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/markdown": "8.0.1",
    "@html-eslint/eslint-plugin": "0.60.0",
    "@html-eslint/parser": "0.60.0",
    "@playwright/test": "1.60.0",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@tsconfig/node-ts": "23.6.4",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@vitest/browser-playwright": "4.1.6",
    "dotenv": "17.4.2",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-json": "4.0.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-svelte": "3.17.0",
    "globals": "17.6.0",
    "markdownlint-cli": "0.48.0",
    "postcss-html": "1.8.1",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "shx": "0.4.0",
    "stylelint": "17.9.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-prettier": "5.0.3",
    "svelte": "5.55.5",
    "svelte-check": "4.4.6",
    "svelte-eslint-parser": "1.6.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.8",
    "vitest": "4.1.6",
    "vitest-browser-svelte": "2.1.1"
  },
  "dependencies": {
    "@summitstreet/svelte-ui-sdk": "2.0.0",
    "@summitstreet/web-app-sdk-ts": "2.0.0"
  }
}
